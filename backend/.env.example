# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# Database Configuration
DB_HOST=localhost
DB_NAME=ayur_db
DB_USER=root
DB_PASSWORD=

# JWT Configuration
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-64-character-secret-key-before-production

# Application Environment
APP_ENV=development

# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=your-firebase-server-key-here

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost,http://10.0.2.2
